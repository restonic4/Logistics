{
  "multipart": [
    {
      "apply": { "model": "logistics:block/cable/core" }
    },
    {
      "when": { "north": "true" },
      "apply": { "model": "logistics:block/cable/connection" }
    },
    {
      "when": { "east": "true" },
      "apply": { "model": "logistics:block/cable/connection", "y": 90 }
    },
    {
      "when": { "south": "true" },
      "apply": { "model": "logistics:block/cable/connection", "y": 180 }
    },
    {
      "when": { "west": "true" },
      "apply": { "model": "logistics:block/cable/connection", "y": 270 }
    },
    {
      "when": { "up": "true" },
      "apply": { "model": "logistics:block/cable/connection", "x": 270 }
    },
    {
      "when": { "down": "true" },
      "apply": { "model": "logistics:block/cable/connection", "x": 90 }
    }
  ]
}